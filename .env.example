# =====================================================================
# Site
# =====================================================================
NEXT_PUBLIC_SITE_URL=https://holadesign.com.br

# =====================================================================
# Payload CMS
# =====================================================================
# Gere com: openssl rand -base64 48
PAYLOAD_SECRET=

# Postgres. Railway usa DATABASE_URL; DATABASE_URI é aceito como fallback.
# Formato: postgres://USER:PASS@HOST:PORT/DB
DATABASE_URL=

# Sincroniza o schema automaticamente no boot (sem rodar migrations manualmente).
# Deixe em branco/true para começar; mude para "false" depois que adotar migrations versionadas.
PAYLOAD_PUSH=true

# =====================================================================
# E-mail (SMTP genérico)
# =====================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@holadesign.com.br
FROM_NAME=¡HOLA! Design
CONTACT_TO_EMAIL=hola@holadesign.com.br

# =====================================================================
# Cloudflare R2 (S3-compatible) — uploads de mídia
# =====================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# URL pública do bucket (custom domain ou pub-*.r2.dev)
R2_PUBLIC_URL=

# =====================================================================
# Feature flags
# =====================================================================
NEXT_PUBLIC_ENABLE_ANALYTICS=false
