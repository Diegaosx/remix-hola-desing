{
  "name": "hola-design",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "¡HOLA! Design — editorial strategy studio website (Next.js 15 + TypeScript)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "tsx scripts/boot.ts && next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "fetch-assets": "tsx scripts/fetch-assets.ts",
    "seed": "tsx scripts/seed.ts",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "migrate": "payload migrate"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.83.0",
    "@payloadcms/email-nodemailer": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/storage-s3": "^3.83.0",
    "@types/nodemailer": "^8.0.0",
    "gray-matter": "4.0.3",
    "next": "15.5.15",
    "next-mdx-remote": "5.0.0",
    "nodemailer": "^8.0.5",
    "payload": "^3.83.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsx": "4.19.2",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.15",
    "@types/node": "22.10.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.20",
    "eslint": "9.17.0",
    "eslint-config-next": "15.5.15",
    "postcss": "8.4.49",
    "sass": "^1.99.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
